# 🧠 Enterprise GraphRAG Knowledge Engine — Environment Variables
# Copy this file to .env and configure the values.

# ── Neo4j Database Configuration ─────────────────────────────────────
# For local development with docker-compose:
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Groq API Configuration ───────────────────────────────────────────
# Get a free Groq API key from Groq Console: https://console.groq.com/
GROQ_API_KEY=GROQ_API_KEY=your_api_key_here
